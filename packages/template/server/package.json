{
  "name": "contextmcp-server",
  "version": "1.0.0",
  "description": "Self-hostable Node.js MCP server for ContextMCP documentation search",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "@modelcontextprotocol/sdk": "1.25.2",
    "@pinecone-database/pinecone": "^6.1.3",
    "dotenv": "^17.2.3",
    "openai": "^6.14.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=18"
  }
}
