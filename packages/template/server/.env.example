# --- Required ---
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=my-docs

# --- Embedding provider (must match how you indexed) ---
EMBEDDING_PROVIDER=openai           # openai | gemini | cohere | voyage | ollama
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072
OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# COHERE_API_KEY=...
# VOYAGE_API_KEY=...
# OLLAMA_BASE_URL=http://localhost:11434

# --- Server ---
PORT=8787
SERVER_NAME=contextmcp
SERVER_DESCRIPTION=Search documentation

# --- Search tuning ---
DEFAULT_TOP_K=10
MAX_TOP_K=20
ENABLE_RERANK=true
RERANK_MODEL=pinecone-rerank-v0
RERANK_FETCH_COUNT=30
MAX_RERANK_CHARS=1200
