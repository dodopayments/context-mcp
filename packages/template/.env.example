# Pinecone API key for vector storage (always required)
PINECONE_API_KEY=...

# Embedding provider key — set the one matching `embeddings.provider` in config.yaml
#
# provider: openai  (default) -> requires OPENAI_API_KEY
OPENAI_API_KEY=sk-...
#
# provider: gemini            -> requires GEMINI_API_KEY
# GEMINI_API_KEY=...
#
# provider: cohere            -> requires COHERE_API_KEY
# COHERE_API_KEY=...
#
# provider: voyage            -> requires VOYAGE_API_KEY
# VOYAGE_API_KEY=...
#
# provider: ollama            -> no API key (local server); set ollama.baseUrl in config.yaml
