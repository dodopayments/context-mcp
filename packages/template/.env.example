# --- Vector store ---
# Pinecone (provider: pinecone) — always required for Pinecone
PINECONE_API_KEY=...

# Qdrant (provider: qdrant) — self-hosted or Qdrant Cloud
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=...   # only needed for Qdrant Cloud

# Embedding provider key — set the one matching `embeddings.provider` in config.yaml
#
# provider: openai  (default) -> requires OPENAI_API_KEY
OPENAI_API_KEY=sk-...
#
# provider: gemini            -> requires GEMINI_API_KEY
# GEMINI_API_KEY=...

# Optional: GitHub token for cloning private GitHub repositories
# GITHUB_TOKEN=...

# Optional: GitLab token for cloning private GitLab repositories
# GITLAB_TOKEN=...
